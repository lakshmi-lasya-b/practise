{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/my-react-app/package.json",
      "use": "@vercel/static",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/my-react-app/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/my-react-app/dist/index.html"
    }
  ]
}
